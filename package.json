{
  "name": "@injectivelabs/ui-layer",
  "type": "module",
  "version": "0.0.1",
  "main": "./nuxt.config.ts",
  "license": "Apache-2.0",
  "scripts": {
    "lint": "eslint --max-warnings 0 '**/*.{js,ts,vue,html}'",
    "lint:fix": "eslint --max-warnings 0 '**/*.{js,ts,vue,html}' --fix",
    "typecheck": "nuxi typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "pnpm nuxt prepare",
    "postinstall": "pnpm upgrade '@injectivelabs/*' --latest",
    "dev:gen:bff-types": "curl -sSf http://localhost:4000/api/openapi.json -o app/generated/bff-spec.json && openapi-typescript app/generated/bff-spec.json -o app/generated/bff.generated.ts && SPEC_PATH=app/generated/bff-spec.json tsx scripts/gen-bff-client.ts",
    "gen:bff-types": "curl -sSf https://bff-api.injective.network/api/openapi.json -o app/generated/bff-spec.json && openapi-typescript app/generated/bff-spec.json -o app/generated/bff.generated.ts && SPEC_PATH=app/generated/bff-spec.json tsx scripts/gen-bff-client.ts"
  },
  "dependencies": {
    "@bangjelkoski/ens-validation": "^0.1.1",
    "@injectivelabs/exceptions": "1.18.11",
    "@injectivelabs/networks": "1.18.11",
    "@injectivelabs/nuxt-bugsnag": "0.0.12",
    "@injectivelabs/sdk-ts": "1.18.11",
    "@injectivelabs/ts-types": "1.18.11",
    "@injectivelabs/utils": "1.18.11",
    "@injectivelabs/wallet-base": "1.18.11",
    "@injectivelabs/wallet-core": "1.18.11",
    "@injectivelabs/wallet-cosmos": "1.18.11",
    "@injectivelabs/wallet-evm": "1.18.11",
    "@injectivelabs/wallet-strategy": "1.18.11",
    "@injectivelabs/wallet-turnkey": "1.18.11",
    "@metamask/eth-sig-util": "^8.2.0",
    "@nuxt/kit": "4.2.2",
    "@nuxt/ui": "4.2.1",
    "@nuxtjs/i18n": "10.2.1",
    "@pinia/nuxt": "0.11.3",
    "@vueuse/integrations": "14.1.0",
    "@vueuse/nuxt": "14.1.0",
    "canvas-confetti": "^1.6.0",
    "date-fns": "^4.1.0",
    "ethers": "^6.13.7",
    "hono": "^4.12.5",
    "js-confetti": "^0.12.0",
    "nuxt": "4.2.2",
    "nuxt-vitalizer": "2.0.0",
    "openapi-fetch": "^0.12.5",
    "qr-code-styling": "^1.9.2",
    "vee-validate": "4.15.1",
    "viem": "^2.41.2",
    "vue-gtag": "2.0.1",
    "vue-hotjar": "1.4.0",
    "vue-imask": "7.6.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.2.0",
    "@commitlint/config-conventional": "20.2.0",
    "@nuxt/eslint": "1.12.1",
    "@nuxt/test-utils": "3.21.0",
    "@types/canvas-confetti": "^1.6.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "9.39.2",
    "eslint-plugin-perfectionist": "4.15.1",
    "happy-dom": "^18.0.1",
    "husky": "9.1.7",
    "openapi-typescript": "^7.13.0",
    "openapi-typescript-helpers": "^0.1.0",
    "playwright-core": "^1.53.1",
    "prettier": "3.7.4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.5",
    "yaml": "^2.8.2"
  },
  "pnpm": {
    "overrides": {
      "rollup": "4.53.3",
      "crypto-js": "4.2.0",
      "@solana/web3.js": "1.98.0"
    }
  }
}
